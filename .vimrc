" Leader

map <Space> <Nop>
 
let mapleader = " "

" Navigation

nnoremap <S-h> :bprevious<CR>
nnoremap <S-l> :bnext<CR>

nnoremap <C-d> <C-d>zz
nnoremap <C-u> <C-u>zz

" Saving

nnoremap <leader>w :w<CR>

" Yoinkless

xnoremap <leader>d "_d
xnoremap <leader>p "_p
" xnoremap <leader>p "_dP
